{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "cd ../.. && npx tsc --build && cd artifacts/api-server && node ./build.mjs",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
